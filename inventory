---
# Example: multi-server setup where nextcloudoffice and whiteboard
# share the same server (office.example.com)
all:

nextcloud:
  hosts:
    nc.exemple.com:
      ansible_user: ansible

redis:
  hosts:
    nc.exemple.com:

database:
  hosts:
    db.exemple.com:
      ansible_user: ansible

elasticsearch:
  hosts:
    nc.exemple.com:

coturn:
  hosts:
    nc.exemple.com:

signal:
  vars:
    additional_certificate_fqdns:
      - recording.exemple.lan
  hosts:
    hpb.exemple.com:
      ansible_user: ansible

hapr:
  hosts:
    nc.exemple.com:

# nextcloudoffice and onlyoffice are mutual exclusive
# choose one or the other
# nextcloudoffice and whiteboard can share the same server

onlyoffice:
  hosts:
    nc.exemple.com:

eurooffice:
  hosts:
    nc.exemple.com:

whiteboard:
  vars:
    additional_fqdns:
      additional_fqdn_whiteboard: nc.exemple.com
  hosts:
    nc.exemple.com:

# webserver and docker groups are managed automatically
# do not edit them even if you don't install a particular service
webserver:
  hosts:
    nc.exemple.com:
    hpb.exemple.com:

docker:
  hosts:
    nc.exemple.com:
    hpb.exemple.com:

# host for your nginx base front end reverse proxy for tls certificate, coturn, and more
# optional 
reverse_proxy:
  hosts:
    #rproxy.exemple.com:
